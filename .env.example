# piiv — secrets and per-invocation overrides only.
#
# Copy to `.env` (gitignored) and fill in what you actually need.
#   cp .env.example .env
#
# Most flags + model names + endpoints live in `piiv.yaml` at the repo
# root. Use this file ONLY for:
#   - secrets (API keys, Fernet vault key) that must not be committed,
#   - per-invocation overrides of YAML values (env > YAML > defaults).
#
# Override precedence (highest → lowest):
#   1. CLI flags (e.g. --second-pass, --opf-model)
#   2. PII_* / PIIV_* env vars below
#   3. piiv.yaml
#   4. Built-in defaults in src/piiv/config.py

# =============================================================================
# Secrets — never appear in YAML
# =============================================================================

# Fernet key for the encrypted PII vault. If unset, an ephemeral key is
# generated per process (fine for dev, breaks vault persistence across runs).
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PII_VAULT_KEY=

# API key for the agent-pipeline LLM used by run_experiment.py.
# Default base_url is https://openrouter.ai/api/v1 (set in piiv.yaml),
# so this is an OpenRouter key (sk-or-v1-...). Model is picked per-run via
# the --llm-model CLI flag; no default model is configured.
# PII_EVAL_API_KEY=

# LLM second-pass detector key. Defaults to PII_EVAL_API_KEY (one
# OpenRouter key serves both the eval LLM and the detector LLM); set
# PII_LLM_API_KEY only if you want a dedicated key for the detector.
# PII_LLM_API_KEY=

# =============================================================================
# Per-invocation overrides (optional — usually edit piiv.yaml instead)
# =============================================================================

# Path to an alternate piiv.yaml (e.g. config/paper-final.yaml).
# PIIV_CONFIG=

# Detector second-pass mode: none | opf | llm | presidio
# Overrides detector.second_pass in piiv.yaml.
# PII_SECOND_PASS=none

# OPF model registry key (e.g. base | en | de | ru). Overrides
# detector.opf.default_model. Must match a key in detector.opf.models.
# PII_OPF_MODEL=base

# OPF inference device — cpu | cuda | mps.
# PII_OPF_DEVICE=cpu

# OPF cheap regex prefilter (skips clean negatives before forward pass).
# PII_OPF_PREFILTER_ENABLED=false

# Cache directory for downloaded OPF checkpoints.
# PII_OPF_CACHE_DIR=

# LLM second-pass overrides (when detector.second_pass=llm). Defaults
# point at OpenRouter; set PII_LLM_BASE_URL to an LM Studio / Ollama /
# vLLM endpoint for fully local inference. Model is forced via the CLI
# (--detector-llm-model) or this env var — no default ships in piiv.yaml.
# PII_LLM_BASE_URL=https://openrouter.ai/api/v1
# PII_LLM_MODEL=nvidia/nemotron-nano-9b-v2:free
# PII_LLM_TIMEOUT=15
# PII_LLM_PREFILTER=true

# First-pass regex policy — `ru` | `en` | `de` | absolute path to a custom YAML.
# PII_REGEX_POLICY=ru

# Pipeline toggles.
# PII_MASKING_ENABLED=true
# PII_LEAK_GUARD_ENABLED=true

# Benchmark eval gate (must be true to run agent-pipeline experiments).
# Model is passed via --llm-model on the CLI (e.g. --llm-model anthropic/claude-sonnet-4-6).
# PII_EVAL_LLM_ENABLED=
# PII_EVAL_BASE_URL=https://openrouter.ai/api/v1

# LLM second-pass detector model + endpoint (when detector.second_pass=llm).
# Same OpenRouter prefix-routing convention as the eval LLM.
# PII_LLM_MODEL=nvidia/nemotron-nano-9b-v2:free
# PII_LLM_BASE_URL=https://openrouter.ai/api/v1
